# Shawn-Bio-Search environment template
# Copy to .env and fill values as needed.

# --- Paper sources (optional but recommended) ---
NCBI_API_KEY=your_ncbi_key_here
SCOPUS_API_KEY=your_scopus_key_here
SCOPUS_INSTTOKEN=your_scopus_token_here
SERPAPI_API_KEY=your_serpapi_key_here

# --- Web augmentation (optional) ---
BRAVE_API_KEY=your_brave_key_here

# --- Kaggle (optional, for --with-kaggle) ---
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key

# --- Cellcog (optional, for --with-cellcog) ---
CELLCOG_URL=https://api.your-cellcog-endpoint.example/v1/search
CELLCOG_API_KEY=your_cellcog_api_key

# --- ORCID / Unpaywall (optional, for --with-orcid / --with-unpaywall) ---
ORCID_PREFERRED_ID=0000-0000-0000-0000
ORCID_CLIENT_ID=your_orcid_client_id_optional
ORCID_CLIENT_SECRET=your_orcid_client_secret_optional
UNPAYWALL_EMAIL=your_email@example.org

# --- Local repository roots (optional) ---
ZOTERO_ROOT=/path/to/Zotero/papers
